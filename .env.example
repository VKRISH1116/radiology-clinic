# ─────────────────────────────────────────────────────────────────────────────
# Deployment environment template for docker-compose.
#
# Copy this to ".env" (which is git-ignored) and fill in REAL values before any
# non-local deployment. docker compose reads ".env" automatically, so these
# override the dev defaults baked into docker-compose.yml.
#
#   cp .env.example .env      # then edit .env
#
# Leave it absent for local dev — the compose defaults are fine on your machine.
# ─────────────────────────────────────────────────────────────────────────────

# --- Database ---------------------------------------------------------------
DB_USER=clinic
DB_PASSWORD=CHANGE_ME_strong_db_password
# Point at an external managed DB (e.g. AWS RDS) here, or leave unset to use the
# bundled "db" container:  jdbc:postgresql://<host>:5432/radiology_clinic
# DB_URL=jdbc:postgresql://db:5432/radiology_clinic

# --- Auth / security --------------------------------------------------------
# MUST be a random string of at least 32 bytes. Generate one, don't reuse this.
JWT_SECRET=CHANGE_ME_random_secret_at_least_32_bytes_long

# The first admin account, created on first startup if it doesn't exist.
BOOTSTRAP_ADMIN_EMAIL=admin@yourclinic.example
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- Web --------------------------------------------------------------------
# The browser origin(s) allowed to call the API (comma-separated). Set to the
# deployed frontend URL, e.g. https://clinic.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
